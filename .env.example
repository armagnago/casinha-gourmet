# Casinha Gourmet - Configuração de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# BANCO DE DADOS
DB_HOST=localhost
DB_USER=root
DB_PASS=sua_senha_aqui
DB_NAME=casinha_gourmet
DB_PORT=3306

# APLICAÇÃO
APP_NAME=Casinha Gourmet
APP_URL=https://casinhagourmet.com
APP_DESIGN=design1
DEBUG_MODE=false

# EMAIL (SMTP)
SMTP_HOST=smtp.seuhost.com
SMTP_PORT=587
SMTP_USER=seu-email@dominio.com
SMTP_PASS=sua-senha-smtp
OWNER_EMAIL=proprietario@casinhagourmet.com

# STRIPE
STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# AWS S3
AWS_ACCESS_KEY=sua_access_key
AWS_SECRET_KEY=sua_secret_key
AWS_BUCKET=casinha-gourmet
AWS_REGION=us-east-1

# REDES SOCIAIS
WHATSAPP_NUMBER=5511999999999
INSTAGRAM_URL=https://instagram.com/casinhagourmet
FACEBOOK_URL=https://facebook.com/casinhagourmet
